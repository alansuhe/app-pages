{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "app": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "published": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "app",
    "version",
    "date",
    "summary"
  ]
}