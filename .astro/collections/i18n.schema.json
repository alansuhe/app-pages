    "download": {
      "type": "object",
      "properties": {
        "downloadNow": {
          "type": "string"
        },
        "directDownload": {
          "type": "string"
        },
        "appStore": {
          "type": "string"
        },
        "platformSupport": {
          "type": "string"
        },
        "currentVersion": {
          "type": "string"
        },
        "requirements": {
          "type": "string"
