{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "nav": {
      "type": "object",
      "properties": {
        "home": {
          "type": "string"
        },
        "apps": {
          "type": "string"
        },
        "changelog": {
          "type": "string"
        },
        "faq": {
          "type": "string"
        },
        "privacy": {
          "type": "string"
        },
        "terms": {
          "type": "string"
        }
      },
      "required": [
        "home",
        "apps",
        "changelog",
        "faq",
        "privacy",
        "terms"
      ]
    },
    "footer": {
      "type": "object",
      "properties": {
        "copyright": {
          "type": "string"
        },
        "rights": {
          "type": "string"
        }
      },
      "required": [
        "copyright",
        "rights"
      ]
    },
    "common": {
      "type": "object",
      "properties": {
        "download": {
          "type": "string"
        },
        "learnMore": {
          "type": "string"
        },
        "viewChangelog": {
          "type": "string"
        },
        "availablePlatforms": {
          "type": "string"
        },
        "comingSoon": {
          "type": "string"
        },
        "beta": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "released": {
          "type": "string"
        }
      },
      "required": [
        "download",
        "learnMore",
        "viewChangelog",
        "availablePlatforms",
        "comingSoon",
        "beta",
        "version",
        "released"
      ]
    },
    "apps": {
      "type": "object",
      "properties": {
        "allApps": {
          "type": "string"
