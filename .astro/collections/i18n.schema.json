      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description"
      ]
    },
    "legal": {
      "type": "object",
      "properties": {
        "lastUpdated": {
          "type": "string"
        }
      },
      "required": [
        "lastUpdated"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "nav",
    "footer",
    "common",
    "apps",
    "download",
    "changelog",
    "faqPage",
    "legal"
