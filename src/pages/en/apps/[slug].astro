---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { getTranslations, buildUrl, type Language } from '@/i18n/utils';

export async function getStaticPaths() {
  const appsEn = await getCollection('apps', ({ id }) => id.startsWith('en/'));
  const appsZh = await getCollection('apps', ({ id }) => id.startsWith('zh-cn/'));

  const paths = [];

  for (const app of appsEn) {
    paths.push({
      params: { slug: app.data.slug },
      props: { lang: 'en' as Language, appSlug: app.data.slug },
    });
  }

  for (const app of appsZh) {
    paths.push({
      params: { slug: app.data.slug },
      props: { lang: 'zh-cn' as Language, appSlug: app.data.slug },
    });
  }

  return paths;
}

const { slug } = Astro.params;
const { lang } = Astro.props;

const app = await getEntry('apps', `${lang}/${slug}`);
const translations = await getTranslations(lang);

if (!app) {
  return Astro.redirect(buildUrl(`/${lang}/apps/`));
}
---

<BaseLayout lang={lang} title={app.data.title} description={app.data.tagline}>
  <article class="app-detail">
    <header class="app-header">
      {app.data.heroImage && (
        <img src={app.data.heroImage} alt={app.data.title} class="hero-image" />
      )}
      <div class="app-info">
        <h1>{app.data.title}</h1>
        <p class="tagline">{app.data.tagline}</p>
        <div class="status-badge" data-status={app.data.status}>
          {app.data.status === 'available'
            ? translations?.common.download
            : app.data.status === 'beta'
              ? translations?.common.beta
              : translations?.common.comingSoon}
        </div>
      </div>
    </header>

    <section class="app-content">
      <h2>About</h2>
      <p>{app.data.description}</p>

      <h2>{translations?.common.availablePlatforms ?? 'Platform Support'}</h2>
      <ul class="platforms">
        {app.data.platforms.map((platform) => (
          <li>{platform.toUpperCase()}</li>
        ))}
      </ul>
    </section>

    <section class="app-actions">
      <a href={buildUrl(`/${lang}/download/${app.data.slug}/`)} class="btn btn-primary">
        {translations?.common.download ?? 'Download'}
      </a>
      <a href={buildUrl(`/${lang}/changelog/?app=${app.data.slug}`)} class="btn btn-outline">
        {translations?.common.viewChangelog ?? 'View Changelog'}
      </a>
      <a href={buildUrl(`/${lang}/faq/`)} class="btn btn-outline">
        {translations?.nav.faq ?? 'FAQ'}
      </a>
    </section>
  </article>
</BaseLayout>

<style>
  .app-detail {
    max-width: 800px;
  }

  .app-header {
    margin-bottom: var(--spacing-xl);
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--radius);
    margin-bottom: var(--spacing-lg);
  }

  .app-info h1 {
    margin-bottom: var(--spacing-sm);
  }

  .tagline {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-bottom: var(--spacing-md);
  }

  .status-badge {
    display: inline-block;
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius);
    font-weight: 500;
    background: var(--color-card-bg);
  }

  .status-badge[data-status="available"] {
    background: var(--color-primary);
    color: var(--color-bg);
  }

  .status-badge[data-status="beta"] {
    background: #ffc107;
    color: #1a1a1a;
  }

  .app-content {
    margin-bottom: var(--spacing-xl);
  }

  .app-content h2 {
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  .platforms {
    list-style: none;
    display: flex;
    gap: var(--spacing-sm);
  }

  .platforms li {
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--color-card-bg);
    border-radius: var(--radius);
    font-weight: 500;
  }

  .app-actions {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }
</style>